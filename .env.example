# Miyaabi full-stack Next.js app — required environment variables.
# Copy to .env.local for local dev; set the same keys in Vercel for production.

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?appName=miyaabi

# --- Admin auth (JWT signed/verified with jose) ---
JWT_SECRET=<long-random-string>
JWT_EXPIRES_IN=7d

# --- Cloudinary (signed direct-to-browser uploads) ---
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# --- Upstash Redis (rate limiting; optional — omit to disable / fail-open) ---
UPSTASH_REDIS_REST_URL=https://<your>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>
